{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["padel", "postgres", "database"],
  "title": "Padel Club Admin — Postgres",
  "uid": "padel-postgres",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Postgres up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "pg_up" }]
    },
    {
      "id": 2,
      "title": "Active connections (by db)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_stat_database_numbackends{datname=\"padel\"}",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Database size",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_database_size_bytes{datname=\"padel\"}",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Commits / Rollbacks (per s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(pg_stat_database_xact_commit{datname=\"padel\"}[5m])",
          "legendFormat": "commits"
        },
        {
          "refId": "B",
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"padel\"}[5m])",
          "legendFormat": "rollbacks"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cache hit ratio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(pg_stat_database_blks_hit{datname=\"padel\"}[5m]) / clamp_min(rate(pg_stat_database_blks_hit{datname=\"padel\"}[5m]) + rate(pg_stat_database_blks_read{datname=\"padel\"}[5m]), 1)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 6,
      "title": "Tuple activity (per s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(pg_stat_database_tup_fetched{datname=\"padel\"}[5m])",
          "legendFormat": "fetched"
        },
        {
          "refId": "B",
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"padel\"}[5m])",
          "legendFormat": "inserted"
        },
        {
          "refId": "C",
          "expr": "rate(pg_stat_database_tup_updated{datname=\"padel\"}[5m])",
          "legendFormat": "updated"
        },
        {
          "refId": "D",
          "expr": "rate(pg_stat_database_tup_deleted{datname=\"padel\"}[5m])",
          "legendFormat": "deleted"
        }
      ]
    }
  ]
}
