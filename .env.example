# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Database ---
# Local dev (default): start a local Postgres with `bun run db:up`, then
# `bun run db:push && bun run db:seed`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5544/padel
#
# Production: use a Neon pooled connection string. Set this in the Vercel
# project's environment variables (NOT here). It looks like:
#   postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# --- Better Auth ---
# Secret used to sign sessions/cookies. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of the app (used for auth callbacks). Local dev default below.
BETTER_AUTH_URL=http://localhost:3003
